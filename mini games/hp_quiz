print("There will be 10 multiple-choice questions. Please choose an answer, and your score will be calculated at the end :)") 

score = 0
        
def prompt(question_number):
    print(question_number["question"])
    
    for letter, choice in question_number ["choices"].items():
        print(f"{letter}. {choice}") 
        
    user_answer = input("Please enter A, B or C as your answer: ").upper()
    
    if user_answer == question_number["answer"]: 
        print(f"\nWell Done! {user_answer} was correct!\n")
        return 1
    else:
        print(f"\nNot quite :(. The correct answer was {question_number['answer']}\n") 
        return 0 

