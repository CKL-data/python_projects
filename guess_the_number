import random

correct_number = random.randint(1, 10)

player_name = input("What is your name?") 

guesses = 0 

print(f"Hi, {(player_name)}! Can you guess the correct number between 1-10?")


while True:
    
    user_guess = int(input("What is your guess?")) 
    
    if user_guess < 1 or user_guess > 10:
        print("Please guess the correct number between 1-10")
        continue 
        
    guesses += 1 
        
    if user_guess == correct_number:
        print(f"Well done! {(user_guess)} was the correct number!")
        print(f"You won in {(guesses)} guesses!") 
        break
        
    elif user_guess < correct_number:
        print("Your guess is too low, try again!") 
    else:
        print("Your guess is too high, try again!") 
        
    if guesses == 5: 
        print("You have run out of guesses :(") 
        print(f"The correct answer was {(correct_number)}") 
        print("Thank you for playing!") 
        break 
    
    remaining = 5 - guesses
    print(f"You have {(remaining)} guesses remaining!") 
